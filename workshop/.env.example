# ---------------------------------------------------------------------------
# Workshop secrets template. Keep this alongside the notebooks in workshop/.
#
# Copy this file to .env.local (which is gitignored) and fill in your values:
#
#     cp .env.example .env.local        # then edit .env.local
#
# CLI flow — export the vars, then launch Jupyter from this folder:
#     set -a && source .env.local && set +a && jupyter lab
#
# VS Code (Jupyter extension) — open workshop/ as the workspace, then point
# the Python env file at it so the kernel inherits the key:
#     "python.envFile": "${workspaceFolder}/.env.local"
#
# Use plain KEY="value" lines (no `export`) so both the shell and VS Code's
# env-file parser read them correctly.
# ---------------------------------------------------------------------------

# Your NEXUS API key (required to run the notebooks). Format: ak_...
FUNDAMENTAL_API_KEY="ak_replace_me"

# Cloudsmith token to install the Fundamental SDK from the private repo
# (required for the pip install step in setup).
CLOUDSMITH_FUNDAMENTAL_TOKEN="replace_me"

# Optional — per-environment keys for the Module 08 multi-environment demo.
# If these are unset, the workshop falls back to FUNDAMENTAL_API_KEY above.
# FUNDAMENTAL_API_KEY_DEV="ak_..."
# FUNDAMENTAL_API_KEY_STG="ak_..."
# FUNDAMENTAL_API_KEY_PROD="ak_..."
